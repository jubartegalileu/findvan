# ============================================================
# FINDVAN OSINT + SDR - Application Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local with real credentials

# ============================================================
# Database Configuration (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://findvan:findvan_password@localhost:5432/findvan_db
DATABASE_ECHO=false
DB_HOST=localhost
DB_PORT=5432
DB_NAME=findvan_db
DB_USER=findvan
DB_PASSWORD=findvan_password

# ============================================================
# Redis Configuration (Cache & Queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
# Backend (FastAPI)
# ============================================================
BACKEND_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development
BACKEND_DEBUG=true
BACKEND_SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# ============================================================
# Frontend (React + Electron)
# ============================================================
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
ELECTRON_DEV_MODE=true

# ============================================================
# Module 1: Scraper Configuration
# ============================================================

# Google Maps API (optional, if using official API)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_ENABLED=false

# Browser automation
PUPPETEER_HEADLESS=true
PUPPETEER_SKIP_DOWNLOAD=false
PUPPETEER_EXECUTABLE_PATH=

# Proxy for scraping (optional)
USE_PROXY=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# Scraper settings
SCRAPER_DELAY_MS=1000
SCRAPER_TIMEOUT_MS=30000
SCRAPER_RETRY_COUNT=3
SCRAPER_LOG_LEVEL=info

# ============================================================
# Module 4: WhatsApp Integration
# ============================================================

# Twilio Sandbox (for development/testing)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SANDBOX_ENABLED=true

# WhatsApp Business API (production)
WHATSAPP_API_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_BUSINESS_ACCESS_TOKEN=

# ============================================================
# Logging & Monitoring
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
SENTRY_DSN=
SENTRY_ENABLED=false

# ============================================================
# Environment Flags
# ============================================================
NODE_ENV=development
PYTHONPATH=.
DEBUG_MODE=true

# ============================================================
# External Services
# ============================================================
# For CNPJ lookup (if using external API)
CNPJ_API_KEY=

# For OLX/marketplace scraping
OLX_API_ENABLED=false

# For LinkedIn API (if using)
LINKEDIN_API_KEY=

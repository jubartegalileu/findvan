{
  "name": "findvan-osint-sdr",
  "version": "1.0.0",
  "description": "OSINT + SDR Desktop App for School Transportation Prospecting",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "setup": "npm install && npm run setup:python && npm run setup:docker",
    "setup:python": "cd packages/backend && python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
    "setup:docker": "docker-compose -f .docker/docker-compose.yml up -d",
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:scraper\" \"npm run dev:backend\" \"npm run dev:dashboard\"",
    "dev:scraper": "cd packages/scraper && npm run dev",
    "dev:backend": "cd packages/backend && source venv/bin/activate && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:dashboard": "cd packages/dashboard && npm run dev",
    "build": "npm run build:scraper && npm run build:dashboard",
    "build:scraper": "cd packages/scraper && npm run build",
    "build:dashboard": "cd packages/dashboard && npm run build",
    "test": "npm run test:scraper && npm run test:backend && npm run test:dashboard",
    "test:scraper": "cd packages/scraper && npm test",
    "test:backend": "cd packages/backend && source venv/bin/activate && pytest tests/ --cov=app --cov-report=html",
    "test:dashboard": "cd packages/dashboard && npm test",
    "lint": "npm run lint:scraper && npm run lint:dashboard",
    "lint:scraper": "cd packages/scraper && npm run lint",
    "lint:dashboard": "cd packages/dashboard && npm run lint",
    "typecheck": "npm run typecheck:scraper && npm run typecheck:dashboard",
    "typecheck:scraper": "cd packages/scraper && npm run typecheck",
    "typecheck:dashboard": "cd packages/dashboard && npm run typecheck",
    "docker:up": "docker-compose -f .docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f .docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f .docker/docker-compose.yml logs -f",
    "runtime:up": "bash scripts/runtime-profile.sh up",
    "runtime:down": "bash scripts/runtime-profile.sh down",
    "runtime:status": "bash scripts/runtime-profile.sh status",
    "runtime:health": "bash scripts/runtime-profile.sh health",
    "qa:smoke:e2e": "bash scripts/qa-smoke-e2e.sh",
    "qa:smoke:e2e:external": "MANAGE_RUNTIME=0 bash scripts/qa-smoke-e2e.sh",
    "scraper:run": "cd packages/scraper && npm run scraper:google-maps",
    "clean": "rm -rf node_modules coverage .npm-cache && npm cache clean --force",
    "validate:agents": "node .aios-core/infrastructure/scripts/validate-agents.js",
    "validate:structure": "node .aios-core/infrastructure/scripts/validate-paths.js"
  },
  "keywords": [
    "osint",
    "sdr",
    "prospecting",
    "transportation",
    "electron",
    "react",
    "fastapi",
    "puppeteer"
  ],
  "author": "You + Sócio",
  "license": "MIT",
  "devDependencies": {
    "@aios-fullstack/pro": "^0.1.3",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "eslint": "^8",
    "typescript": "^5"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^6.20.0",
    "shadcn-ui": "^0.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  }
}

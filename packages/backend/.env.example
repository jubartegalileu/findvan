# PostgreSQL Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/findvan
DB_HOST=localhost
DB_PORT=5432
DB_NAME=findvan
DB_USER=postgres
DB_PASSWORD=postgres

# Connection Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_STATEMENT_CACHE_SIZE=0

# API Server
API_PORT=3001
API_HOST=0.0.0.0

# Environment
NODE_ENV=development

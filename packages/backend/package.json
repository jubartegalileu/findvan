{
  "name": "findvan-backend",
  "version": "1.0.0",
  "description": "FindVan Backend - Database & API Layer",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "node --test tests/**/*.test.js",
    "test:db": "node --test tests/db/**/*.test.js",
    "test:whatsapp": "node --test tests/services/whatsapp.test.js tests/services/queue.test.js tests/services/template.test.js tests/services/ratelimiter.test.js tests/services/campaign.test.js tests/routes/whatsapp.test.js",
    "migrate": "node src/db/migrate.js",
    "lint": "eslint src tests"
  },
  "keywords": [
    "database",
    "postgresql",
    "leads",
    "osint",
    "whatsapp",
    "sdr"
  ],
  "author": "FindVan Team",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.11.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "bullmq": "^4.0.0",
    "twilio": "^3.80.0",
    "node-cron": "^3.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}

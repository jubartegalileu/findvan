{
  "name": "findvan-backend",
  "version": "1.0.0",
  "description": "FindVan Backend - Database & API Layer",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "node --test tests/**/*.test.js",
    "test:db": "node --test tests/db/**/*.test.js",
    "migrate": "node src/db/migrate.js",
    "lint": "eslint src tests"
  },
  "keywords": [
    "database",
    "postgresql",
    "leads",
    "osint"
  ],
  "author": "FindVan Team",
  "license": "MIT",
  "dependencies": {
    "pg": "^8.11.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
